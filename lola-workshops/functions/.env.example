# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Mailchimp Configuration
# Get your API key from: https://admin.mailchimp.com/account/api/
MAILCHIMP_API_KEY=your_mailchimp_api_key_here

# Get your List ID from: Audience > Settings > Audience name and defaults
MAILCHIMP_LIST_ID=your_mailchimp_list_id_here

# Server prefix (e.g., us21, us1, etc.) - found in your Mailchimp API key or account URL
MAILCHIMP_SERVER_PREFIX=us21

