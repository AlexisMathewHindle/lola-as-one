# Firebase Configuration
FIREBASE_PROJECT_ID=lola-workshops
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase Firestore Collection Names
FIREBASE_EVENTS_COLLECTION=events
FIREBASE_BOOKINGS_COLLECTION=bookings
FIREBASE_CATEGORIES_COLLECTION=categories
FIREBASE_THEMES_COLLECTION=themes

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Migration Settings
DRY_RUN=true
BATCH_SIZE=10
LOG_LEVEL=info

# Output Paths
EXPORT_DIR=./exports
LOGS_DIR=./logs

